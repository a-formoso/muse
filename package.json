{
  "name": "muse",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "tsx server.ts",
    "build": "vite build && esbuild server.ts --bundle --platform=node --format=cjs --packages=external --sourcemap --outfile=dist/server.cjs",
    "start": "node dist/server.cjs",
    "clean": "rm -rf dist server.cjs",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.100.1",
    "@supabase/supabase-js": "^2.106.2",
    "@tailwindcss/vite": "^4.3.0",
    "@vitejs/plugin-react": "^5.2.0",
    "dotenv": "^17.4.2",
    "drizzle-zod": "^0.8.3",
    "express": "^4.22.2",
    "lucide-react": "^0.546.0",
    "motion": "^12.40.0",
    "p-limit": "^7.3.0",
    "p-retry": "^7.1.1",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "zod": "^4.4.3",
    "zod-validation-error": "^5.0.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.25",
    "@types/node": "^22.19.19",
    "autoprefixer": "^10.5.0",
    "esbuild": "^0.25.12",
    "tailwindcss": "^4.3.0",
    "tsx": "^4.22.3",
    "typescript": "~5.8.2",
    "vite": "^6.4.2"
  }
}
