# Copy this file to .env (or .env.local) and fill in your values.
# In production (Replit), set these in the Secrets panel instead of committing a file.

# --- Required ---

# ANTHROPIC_API_KEY: Anthropic Claude API key. Powers all story/text generation (Phases 1-3 + virality).
ANTHROPIC_API_KEY="MY_ANTHROPIC_API_KEY"

# --- Supabase (auth + project persistence) ---

# SUPABASE_URL: Your Supabase project URL, e.g. https://xxxx.supabase.co
SUPABASE_URL="MY_SUPABASE_URL"
# SUPABASE_ANON_KEY: Supabase anon/public key.
SUPABASE_ANON_KEY="MY_SUPABASE_ANON_KEY"

# --- Higgsfield (storyboard / shot generation jobs) ---

HIGGSFIELD_API_KEY="MY_HIGGSFIELD_API_KEY"
HIGGSFIELD_SECRET="MY_HIGGSFIELD_SECRET"

# --- Optional ---

# ELEVENLABS_API_KEY: Enables voice synthesis. Leave unset to disable that feature.
ELEVENLABS_API_KEY="MY_ELEVENLABS_API_KEY"

# APP_URL: The URL where this app is hosted (e.g. https://muse.infinitestudioai.com).
# Used for self-referential links and API endpoints.
APP_URL="MY_APP_URL"
